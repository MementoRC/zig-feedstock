# ppc64le: force -mlongcall on zigcpp and zig2 to avoid R_PPC64_REL24 overflow
#
# PowerPC64LE direct-branch instructions have a signed 26-bit displacement
# (+/-32 MB). libzigcpp.a objects (e.g. zig_clang_cc1_main.cpp.o) call LLVM
# functions located in shared libraries far outside that range, producing:
#   R_PPC64_REL24 relocation overflow against <symbol>
# -mlongcall makes GCC/Clang emit indirect calls via the CTR register,
# allowing any-distance calls at the cost of 1-2 extra instructions.
#
# Applied after patches 0001+0002+0003 in cmake_fallback_build.
# Guarded with a CMAKE_SYSTEM_PROCESSOR check so the patch is harmless
# if inadvertently applied to non-ppc64le builds.
--- a/CMakeLists.txt
+++ b/CMakeLists.txt
@@ -713,6 +713,12 @@
 set_property(TARGET zigcpp PROPERTY MSVC_RUNTIME_LIBRARY "MultiThreaded")
 endif()

+# ppc64le: 24-bit relative branches cannot span the >32MB distance to LLVM
+# symbols in shared libs.  Force indirect (CTR-based) calls for all zigcpp TUs.
+if(CMAKE_SYSTEM_PROCESSOR STREQUAL "powerpc64le")
+  target_compile_options(zigcpp PRIVATE -mlongcall)
+endif()
+
 target_include_directories(zigcpp PUBLIC
     ${CLANG_INCLUDE_DIRS}
     ${LLVM_INCLUDE_DIRS}
@@ -914,6 +920,12 @@
 target_include_directories(zig2 PUBLIC stage1)
 target_link_libraries(zig2 LINK_PUBLIC zigcpp)

+# ppc64le: zig2.c is a ~11M-line auto-generated C TU; same 32MB branch limit
+# applies.  Force indirect calls so the linker can resolve all cross-unit refs.
+if(CMAKE_SYSTEM_PROCESSOR STREQUAL "powerpc64le")
+  target_compile_options(zig2 PRIVATE -mlongcall)
+endif()
+
 # Link pthread_atfork stub if it exists (needed for glibc 2.28)
 set(PTHREAD_STUB "$ENV{ZIG_LOCAL_CACHE_DIR}/pthread_atfork_stub.o")
 if(EXISTS "${PTHREAD_STUB}")
