# non-unix: Force dynamic CRT (/MD) for zigcpp to match conda-forge LLVM libs
#
# conda-forge builds LLVM with /MD (dynamic CRT). zig's CMakeLists.txt
# sets zigcpp to "MultiThreaded" (/MT, static CRT). Mixing these causes
# lld-link /failifmismatch errors. Change zigcpp to match LLVM.

--- a/CMakeLists.txt
+++ b/CMakeLists.txt
@@ -708,8 +708,9 @@
     -Wno-comment
   )
 else()
+add_compile_options(/wd4715 /wd4291)
 target_compile_options(zigcpp PRIVATE /Zc:preprocessor)
-set_property(TARGET zigcpp PROPERTY MSVC_RUNTIME_LIBRARY "MultiThreaded")
+set_property(TARGET zigcpp PROPERTY MSVC_RUNTIME_LIBRARY "MultiThreadedDLL")
 endif()
