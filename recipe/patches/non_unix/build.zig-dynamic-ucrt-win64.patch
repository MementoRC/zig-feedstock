# non-unix/win-64: Force dynamic CRT (ucrt.lib) when link_libc=true on MSVC
#
# When building with -Denable-llvm (which sets link_libc=true), zig's build
# system sets exe.root_module.link_libc = true.  On x86_64-windows-msvc the
# bootstrap zig's LLD then auto-adds ucrt.lib (dynamic CRT forwarder).
#
# Upstream CMakeLists.txt sets MSVC_RUNTIME_LIBRARY "MultiThreaded" on zigcpp,
# which bakes /DEFAULTLIB:libucrt (static CRT) into zigcpp.a's object pragmas.
# CMakeLists.txt-02-MD-libzigcpp.patch switches that to MultiThreadedDLL, so
# zigcpp.a's DEFAULTLIB becomes ucrt (dynamic) — matching the bootstrap.
#
# This build.zig patch makes the dynamic-CRT choice explicit and symmetric:
# it sets exe.linkage = .dynamic on Windows/MSVC so zig's own build system
# unambiguously requests ucrt.lib (dynamic), eliminating the bootstrap's
# libucrt.lib vs ucrt.lib duplicate-symbol race regardless of default heuristics.
#
# NOTE: In zig 0.16, `link_mode` was removed from `std.Build.Module`. The
# correct API is `exe.linkage` (a field on `std.Build.Step.Compile` itself).

--- a/build.zig
+++ b/build.zig
@@ -244,6 +244,15 @@

     if (link_libc) {
         exe.root_module.link_libc = true;
+        // On Windows/MSVC, force dynamic CRT (ucrt.lib) to match the
+        // MultiThreadedDLL runtime baked into zigcpp.a's DEFAULTLIB pragmas
+        // (set by CMakeLists.txt-02-MD-libzigcpp.patch).  Without this, zig's
+        // LLD auto-selects static mode and adds libucrt.lib, while zigcpp's
+        // DEFAULTLIB pragma also references it — producing ~40 "duplicate
+        // symbol" lld-link errors (__acrt_iob_func, errno, abort, malloc, ...).
+        if (target.result.os.tag == .windows and target.result.abi == .msvc) {
+            exe.linkage = .dynamic;
+        }
     }

     const is_debug = optimize == .Debug;
