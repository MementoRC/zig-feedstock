--- a/build.zig
+++ b/build.zig
@@ -213,8 +213,19 @@ pub fn build(b: *std.Build) !void {
     exe.use_new_linker = b.option(bool, "new-linker", "Use the new linker");
 
     const use_llvm = b.option(bool, "use-llvm", "Use the llvm backend");
-    exe.use_llvm = use_llvm;
-    exe.use_lld = use_llvm;
+
+    // PowerPC64LE: Force LLVM backend + enable LLD code path
+    // With use_lld=true, Zig goes through src/link/Lld.zig::elfLink()
+    // Patch 0021 intercepts this path and spawns external GCC instead
+    // GCC handles PowerPC64 ABI properly (.TOC., __tls_get_addr, pthread_atfork)
+    if (target.result.cpu.arch == .powerpc64le) {
+        exe.use_llvm = true; // Force LLVM backend for code generation
+        exe.use_lld = true; // Enable LLD code path (intercepted by patch 0021)
+        exe.root_module.link_libc = true; // Force libc linking
+    } else {
+        exe.use_llvm = use_llvm;
+        exe.use_lld = use_llvm;
+    }
 
     if (no_bin) {
         b.getInstallStep().dependOn(&exe.step);
@@ -353,6 +364,14 @@ pub fn build(b: *std.Build) !void {
             exe.root_module.linkSystemLibrary("uuid", .{});
             exe.root_module.linkSystemLibrary("ole32", .{});
         }
+        // GCC 14 + glibc 2.28 compatibility: link stub library for __libc_csu_init/fini
+        if (target.result.os.tag == .linux) {
+            exe.root_module.linkSystemLibrary("csu_compat", .{});
+        }
+        // PowerPC64LE needs libgcc for GPR save/restore functions (_savegpr0_*, _restgpr0_*, etc.)
+        if (target.result.cpu.arch == .powerpc64le) {
+            exe.root_module.linkSystemLibrary("gcc", .{});
+        }
     }
 
